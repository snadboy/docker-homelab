SEMAPHORE_ADMIN_PASSWORD=changeme
SEMAPHORE_ENCRYPTION_KEY=

# Bulletin board (apt-update + beszel-agent summary posts)
BULLETIN_API_URL=https://bulletin.isnadboy.com/api/post
BULLETIN_API_KEY=

# Beszel hub credentials (consumed by ansible/roles/beszel-agent)
# KEY = hub SSH public key shown under "Add System"
# TOKEN = universal token from Settings -> Tokens
BESZEL_AGENT_KEY=
BESZEL_AGENT_TOKEN=

# Technitium DNS admin API token (consumed by ansible/playbooks/technitium-update.yml)
TECHNITIUM_TOKEN=
