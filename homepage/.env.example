# Homepage env — copy to .env and fill in values. .env is gitignored.

# --- Media ---
HOMEPAGE_VAR_PLEX_TOKEN=
HOMEPAGE_VAR_TAUTULLI_KEY=
HOMEPAGE_VAR_OVERSEERR_KEY=

# --- Downloads / *arr ---
HOMEPAGE_VAR_SONARR_KEY=
HOMEPAGE_VAR_RADARR_KEY=
HOMEPAGE_VAR_PROWLARR_KEY=
HOMEPAGE_VAR_SABNZBD_KEY=

# --- Smart Home ---
# HA long-lived access token (Profile → Long-Lived Access Tokens)
HOMEPAGE_VAR_HASS_TOKEN=

# --- Proxmox VE ---
# pveum user token add homepage@pve homepage-token --privsep 0
HOMEPAGE_VAR_PROXMOX_USER=homepage@pve!homepage-token
HOMEPAGE_VAR_PROXMOX_TOKEN=

# --- Proxmox Backup Servers ---
# proxmox-backup-manager user generate-token homepage@pbs homepage-token
# proxmox-backup-manager acl update / Admin --auth-id 'homepage@pbs!homepage-token'
HOMEPAGE_VAR_PBS_ALEXANDRIA_USER=homepage@pbs!homepage-token
HOMEPAGE_VAR_PBS_ALEXANDRIA_TOKEN=
HOMEPAGE_VAR_PBS_SVALBARD_USER=homepage@pbs!homepage-token
HOMEPAGE_VAR_PBS_SVALBARD_TOKEN=

# --- Misc widgets ---
HOMEPAGE_VAR_GOTIFY_CLIENT_TOKEN=
HOMEPAGE_VAR_TECHNITIUM_TOKEN=
