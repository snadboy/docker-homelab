# Required secrets for kiosk-data sidecar.
# Copy to .env on the host and fill in real values (do NOT commit .env).

# UniFi (local controller, local account, no MFA)
UNIFI_HOST=https://192.168.86.1
UNIFI_USERNAME=claude2
UNIFI_PASSWORD=
UNIFI_SITE=default

# Proxmox (tainer@pve!main token, Administrator on /)
PVE_HOST=https://colossus.isnadboy.com
PVE_TOKEN_ID=tainer@pve!main
PVE_TOKEN_SECRET=

# Home Assistant (long-lived access token, used for outside temp)
HASS_SERVER=http://192.168.86.224:8123
HASS_TOKEN=
# Optional: pin to a specific weather entity, e.g. weather.home or sensor.outside_temperature_f
HASS_WEATHER_ENTITY=

# Proxmox Backup Server instances — JSON list. Each entry needs:
#   name (display), host (FQDN), datastore (name), token ("user@realm!tokenname:secret")
# Example:
# PBS_INSTANCES_JSON=[{"name":"svalbard","host":"host-svalbard.isnadboy.com","datastore":"backups-ssd","token":"root@pam!status-dashboard:..."}]
PBS_INSTANCES_JSON=[]
